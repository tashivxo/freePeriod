{
	"inputs": [
		{
			"id": "SUPABASE_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Supabase Personal Access Token (from supabase.com/dashboard/account/tokens)",
			"password": true
		}
	],
	"servers": {
		"supabase": {
			"command": "npx",
			"args": [
				"-y",
				"@supabase/mcp-server-supabase@latest",
				"--project-ref",
				"ghkswjpjbymtzpajcyvz"
			],
			"env": {
				"SUPABASE_ACCESS_TOKEN": "${input:SUPABASE_ACCESS_TOKEN}"
			}
		}
	}
}