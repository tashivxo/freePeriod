# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Gemini (free tier AI)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key

# PDF export — DOCX is converted via Gotenberg (required on Vercel; LibreOffice cannot run in serverless)
# Deploy Gotenberg separately (Railway, Fly.io, etc.) and point this at its base URL.
GOTENBERG_URL=https://your-gotenberg-instance.example.com

# Local dev only — use LibreOffice installed on the machine instead of Gotenberg
# PDF_CONVERSION_METHOD=libreoffice
